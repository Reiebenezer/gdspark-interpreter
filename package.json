{
  "name": "@reiebenezer/gdspark-interpreter",
  "version": "1.1.7",
  "description": "Internal interpreter utilities for running GDSpark command flows in frontend applications.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./interpreter": {
      "types": "./dist/interpreter.d.ts",
      "import": "./dist/interpreter.js"
    },
    "./scenario": {
      "types": "./dist/scenario.d.ts",
      "import": "./dist/scenario.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gdspark",
    "gds",
    "interpreter",
    "frontend"
  ],
  "license": "MIT",
  "dependencies": {
    "@reiebenezer/gdspark-parser": "latest",
    "@reiebenezer/ts-utils": "^0.2.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
